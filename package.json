{
  "name": "my-custom-theme",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "npx @tailwindcss/cli -i ./src/input.css -o ./dist/output.css --watch",
    "build": "npx @tailwindcss/cli -i ./src/input.css -o ./dist/output.css --minify",
    "blocks:dev": "webpack --config webpack.config.js --watch --mode development",
    "blocks:build": "webpack --config webpack.config.js --mode production"
  },
