{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goliath/comp-documentation",
  "title": "Compliance – Documentation",
  "description": "Dark 3-column documentation cards section.",
  "category": "goliath",
  "icon": "media-document",
  "keywords": ["compliance", "documentation", "certification"],
  "textdomain": "my-custom-theme",
  "render": "file:./render.php",
  "attributes": {
    "heading":   { "type": "string", "default": "Transparent Documentation and Certification" },
    "subtitle":  { "type": "string", "default": "To support compliance requirements, Goliath™ provides access to detailed documentation." },
    "card1H3":   { "type": "string", "default": "Compliance Certification" },
    "card1Sub":  { "type": "string", "default": "From independent testing" },
    "card2H3":   { "type": "string", "default": "Technical Specs" },
    "card2Sub":  { "type": "string", "default": "Performance data and specifications" },
    "card3H3":   { "type": "string", "default": "Price Comparison" },
    "card3Sub":  { "type": "string", "default": "Insights vs. traditional methods" },
    "closing":   { "type": "string", "default": "Downloadable PDFs are also available to support internal reviews, safety documentation, and procurement decisions. Our resources make it easier to show due diligence in the process and to explain clearly how Goliath™ contributes to safety and compliance." }
  },
  "supports": {
    "html": false,
    "align": false
  }
}
