{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goliath/stats-strip",
  "title": "Goliath Stats Strip",
  "description": "Dark horizontal strip showing 3\u20134 key statistics (value + label). Used on the homepage and service pages.",
  "category": "goliath",
  "icon": "chart-bar",
  "keywords": [
    "stats",
    "kpi",
    "numbers",
    "metrics"
  ],
  "textdomain": "my-custom-theme",
  "render": "file:./render.php",
  "attributes": {
    "stat1Value": {
      "type": "string",
      "default": "70%"
    },
    "stat1Label": {
      "type": "string",
      "default": "Cost saving vs replacement"
    },
    "stat2Value": {
      "type": "string",
      "default": "30 mins"
    },
    "stat2Label": {
      "type": "string",
      "default": "Average installation time"
    },
    "stat3Value": {
      "type": "string",
      "default": "Lifetime"
    },
    "stat3Label": {
      "type": "string",
      "default": "Structural warranty"
    },
    "stat4Value": {
      "type": "string",
      "default": ""
    },
    "stat4Label": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "align": false
  }
}
