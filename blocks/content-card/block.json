{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goliath/content-card",
  "title": "Goliath Content Card",
  "description": "Icon + heading + body text tile. Use multiple cards in a row for feature lists, benefit grids, result cards, and service overviews.",
  "category": "goliath",
  "icon": "grid-view",
  "keywords": [
    "card",
    "icon",
    "feature",
    "benefit",
    "result",
    "tile"
  ],
  "textdomain": "my-custom-theme",
  "render": "file:./render.php",
  "attributes": {
    "heading": {
      "type": "string",
      "default": ""
    },
    "body": {
      "type": "string",
      "default": ""
    },
    "iconUrl": {
      "type": "string",
      "default": ""
    },
    "background": {
      "type": "string",
      "enum": [
        "light",
        "dark",
        "white"
      ],
      "default": "light"
    },
    "headingColor": {
      "type": "string",
      "enum": [
        "black",
        "orange"
      ],
      "default": "black"
    }
  },
  "supports": {
    "html": false,
    "align": false
  }
}
