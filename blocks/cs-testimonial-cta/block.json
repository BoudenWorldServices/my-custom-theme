{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goliath/cs-testimonial-cta",
  "title": "Case Study \u2013 Testimonial CTA",
  "description": "Orange CTA section. Shows a client testimonial quote if provided; otherwise a 'Ready to Get Similar Results?' heading. Always shows the CTA button.",
  "category": "goliath",
  "icon": "format-quote",
  "keywords": ["case study", "testimonial", "cta"],
  "textdomain": "my-custom-theme",
  "render": "file:./render.php",
  "attributes": {
    "client":       { "type": "string", "default": "" },
    "quote":        { "type": "string", "default": "" },
    "attribution":  { "type": "string", "default": "" },
    "ctaText":      { "type": "string", "default": "Get Similar Results" },
    "ctaUrl":       { "type": "string", "default": "/contact/" }
  },
  "supports": {
    "html": false,
    "align": false,
    "multiple": false
  }
}
