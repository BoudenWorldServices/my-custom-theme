{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goliath/callout-box",
  "title": "Goliath Callout Box",
  "description": "Inline orange, dark, or gray box with bold text and optional arrow. Use as pull-quotes, highlight strips, and inline callouts within page sections.",
  "category": "goliath",
  "icon": "megaphone",
  "keywords": ["callout", "quote", "highlight", "box", "strip", "pull quote"],
  "textdomain": "my-custom-theme",
  "render": "file:./render.php",
  "attributes": {
    "text": { "type": "string", "default": "" },
    "subtext": { "type": "string", "default": "" },
    "theme": { "type": "string", "enum": ["orange", "dark", "gray"], "default": "orange" },
    "showArrow": { "type": "boolean", "default": true },
    "layout": { "type": "string", "enum": ["full-width", "inset"], "default": "full-width" }
  },
  "supports": { "html": false, "align": false }
}
