{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goliath/svc-comparison",
  "title": "Services – Comparison Table",
  "description": "New installation comparison table with before/after rows and bottom banner.",
  "category": "goliath",
  "icon": "table-col-before",
  "keywords": ["services", "comparison", "table"],
  "textdomain": "my-custom-theme",
  "render": "file:./render.php",
  "attributes": {
    "heading":       { "type": "string", "default": "New Installation Comparison" },
    "description":   { "type": "string", "default": "See how GOLIATH™-protected racking compares to standard new installations over the lifetime of your warehouse." },
    "bannerHeading": { "type": "string", "default": "Smart Investment = Long-Term Savings" },
    "bannerDesc":    { "type": "string", "default": "Protect your new warehouse infrastructure from day one and eliminate future repair costs" },
    "row1LeftTitle":  { "type": "string", "default": "Standard new racking upright" },
    "row1LeftDesc":   { "type": "string", "default": "Vulnerable to impact damage from day one" },
    "row1RightTitle": { "type": "string", "default": "New racking with GOLIATH™" },
    "row1RightDesc":  { "type": "string", "default": "Protected against all impact damage permanently" },
    "row2LeftTitle":  { "type": "string", "default": "£675+ per replacement when damaged" },
    "row2LeftDesc":   { "type": "string", "default": "Recurring expense with each incident" },
    "row2RightTitle": { "type": "string", "default": "£0 future repair costs" },
    "row2RightDesc":  { "type": "string", "default": "One-time investment with lifetime protection" },
    "row3LeftTitle":  { "type": "string", "default": "2-4 hours downtime per replacement" },
    "row3LeftDesc":   { "type": "string", "default": "Repeated disruptions to operations" },
    "row3RightTitle": { "type": "string", "default": "Zero downtime after installation" },
    "row3RightDesc":  { "type": "string", "default": "Uninterrupted warehouse productivity" },
    "row4LeftTitle":  { "type": "string", "default": "No warranty against impact damage" },
    "row4LeftDesc":   { "type": "string", "default": "Full financial risk on your business" },
    "row4RightTitle": { "type": "string", "default": "Lifetime impact warranty included" },
    "row4RightDesc":  { "type": "string", "default": "Complete protection with no-questions-asked coverage" }
  },
  "supports": { "html": false, "align": false }
}
