{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goliath/service-tick-list",
  "title": "Service – Tick List Section",
  "description": "Section with a heading, tick-marked list of items, optional image, and CTA button.",
  "category": "goliath",
  "icon": "list-view",
  "keywords": ["service", "tick list", "features"],
  "textdomain": "my-custom-theme",
  "render": "file:./render.php",
  "attributes": {
    "heading": { "type": "string", "default": "Compatible with:" },
    "items":   { "type": "array",  "default": ["Adjustable pallet racking (APR)", "Wide aisle racking", "Narrow aisle racking", "High-bay warehouse systems"], "items": { "type": "string" } },
    "image":   { "type": "string", "default": "" },
    "imageAlt": { "type": "string", "default": "" },
    "ctaText": { "type": "string", "default": "" },
    "ctaUrl":  { "type": "string", "default": "/contact/" }
  },
  "supports": {
    "html": false,
    "align": false
  }
}
