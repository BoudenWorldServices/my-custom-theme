{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goliath/cs-results",
  "title": "Case Study \u2013 Results",
  "description": "Results section with an image, intro text, up to four result cards in a two-column grid, and an optional dark warranty panel.",
  "category": "goliath",
  "icon": "chart-bar",
  "keywords": ["case study", "results", "metrics"],
  "textdomain": "my-custom-theme",
  "render": "file:./render.php",
  "attributes": {
    "resultsImage":  { "type": "string", "default": "" },
    "resultsIntro":  { "type": "string", "default": "" },
    "result1Title":  { "type": "string", "default": "" },
    "result1Text":   { "type": "string", "default": "" },
    "result2Title":  { "type": "string", "default": "" },
    "result2Text":   { "type": "string", "default": "" },
    "result3Title":  { "type": "string", "default": "" },
    "result3Text":   { "type": "string", "default": "" },
    "result4Title":  { "type": "string", "default": "" },
    "result4Text":   { "type": "string", "default": "" },
    "warrantyText":  { "type": "string", "default": "" }
  },
  "supports": {
    "html": false,
    "align": false,
    "multiple": false
  }
}
