{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goliath/media-gallery",
  "title": "Goliath Media Gallery",
  "description": "Row of 2 or 3 equal-height images. Used for warehouse photos, product shots, and site photography.",
  "category": "goliath",
  "icon": "format-gallery",
  "keywords": [
    "gallery",
    "images",
    "photos",
    "row"
  ],
  "textdomain": "my-custom-theme",
  "render": "file:./render.php",
  "attributes": {
    "image1": {
      "type": "string",
      "default": ""
    },
    "image1Alt": {
      "type": "string",
      "default": ""
    },
    "image2": {
      "type": "string",
      "default": ""
    },
    "image2Alt": {
      "type": "string",
      "default": ""
    },
    "image3": {
      "type": "string",
      "default": ""
    },
    "image3Alt": {
      "type": "string",
      "default": ""
    },
    "columns": {
      "type": "string",
      "enum": [
        "2",
        "3"
      ],
      "default": "3"
    },
    "height": {
      "type": "string",
      "enum": [
        "short",
        "medium",
        "tall"
      ],
      "default": "medium"
    },
    "caption": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "align": false
  }
}