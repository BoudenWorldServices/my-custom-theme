{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goliath/svc-regulation",
  "title": "Services – UK Regulation Compliant",
  "description": "Dark section with compliance checklist and certification card.",
  "category": "goliath",
  "icon": "shield",
  "keywords": [
    "services",
    "regulation",
    "compliance"
  ],
  "textdomain": "my-custom-theme",
  "render": "file:./render.php",
  "attributes": {
    "description": {
      "type": "string",
      "default": "GOLIATH™ meets all UK and EU safety standards for new installations. Your project will pass inspections with complete compliance documentation."
    },
    "item1": {
      "type": "string",
      "default": "BS EN 15512:2020 + A1:2022 compliant"
    },
    "item2": {
      "type": "string",
      "default": "BS EN 15635:2008 certified"
    },
    "item3": {
      "type": "string",
      "default": "SEMA codes of practice adherence"
    },
    "item4": {
      "type": "string",
      "default": "Full compliance documentation provided"
    },
    "certH3": {
      "type": "string",
      "default": "Certified Protection"
    },
    "certLine1": {
      "type": "string",
      "default": "UK Registered Design No. 6410620"
    },
    "certLine2": {
      "type": "string",
      "default": "EU Design Registration No. DM/244641"
    },
    "certBanner": {
      "type": "string",
      "default": "Lifetime Warranty Included"
    }
  },
  "supports": {
    "html": false,
    "align": false
  }
}