{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goliath/about-team",
  "title": "About – Our Team",
  "description": "Three-column team member card grid. Falls back to the my_theme_about_team_members option when members attribute is empty.",
  "category": "goliath",
  "icon": "groups",
  "keywords": [
    "about",
    "team",
    "members",
    "staff"
  ],
  "textdomain": "my-custom-theme",
  "render": "file:./render.php",
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Our Team"
    },
    "subtitle": {
      "type": "string",
      "default": "SEMA-qualified inspectors and engineers delivering safe, permanent racking repairs across the UK."
    },
    "members": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "photo": {
            "type": "string"
          },
          "qualifications": {
            "type": "string"
          },
          "bio": {
            "type": "string"
          }
        }
      }
    }
  },
  "supports": {
    "html": false,
    "align": false,
    "multiple": false
  }
}