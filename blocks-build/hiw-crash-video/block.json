{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goliath/hiw-crash-video",
  "title": "How It Works – Crash Test Video",
  "description": "Split band: orange headline panel on the left, full crash test video player on the right.",
  "category": "goliath",
  "icon": "video-alt2",
  "keywords": [
    "crash",
    "video",
    "test",
    "how it works"
  ],
  "textdomain": "my-custom-theme",
  "render": "file:./render.php",
  "attributes": {
    "headline": {
      "type": "string",
      "default": "Install once stop damage for good."
    },
    "videoFile": {
      "type": "string",
      "default": "corporate-crash-test.mp4"
    },
    "videoUrl": {
      "type": "string",
      "default": ""
    },
    "posterUrl": {
      "type": "string",
      "default": ""
    },
    "fallbackText": {
      "type": "string",
      "default": "Watch on video page"
    },
    "fallbackUrl": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "align": false
  }
}