{
  "apiVersion": 2,
  "name": "goliath/svc-split-panel",
  "title": "Service Split Panel",
  "category": "theme",
  "description": "Two-column layout: text/list side + orange callout panel or image.",
  "supports": {
    "html": false
  },
  "attributes": {
    "bgColor": {
      "type": "string",
      "default": "grey"
    },
    "heading": {
      "type": "string",
      "default": ""
    },
    "paragraphs": {
      "type": "array",
      "default": []
    },
    "subHeading": {
      "type": "string",
      "default": ""
    },
    "tickItems": {
      "type": "array",
      "default": []
    },
    "calloutText": {
      "type": "string",
      "default": ""
    },
    "calloutDesc": {
      "type": "string",
      "default": ""
    },
    "image": {
      "type": "string",
      "default": ""
    },
    "imageAlt": {
      "type": "string",
      "default": ""
    },
    "imagePosition": {
      "type": "string",
      "default": "right"
    },
    "ctaText": {
      "type": "string",
      "default": ""
    },
    "ctaUrl": {
      "type": "string",
      "default": ""
    },
    "variant": {
      "type": "string",
      "default": "default"
    },
    "introText": {
      "type": "string",
      "default": ""
    }
  },
  "render": "file:./render.php"
}