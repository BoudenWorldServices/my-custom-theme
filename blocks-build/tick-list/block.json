{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goliath/tick-list",
  "title": "Goliath Tick List",
  "description": "Checklist with tick/check icons. Supports 1 or 2 columns, light or dark theme.",
  "category": "goliath",
  "icon": "yes-alt",
  "keywords": [
    "list",
    "tick",
    "check",
    "bullets",
    "benefits"
  ],
  "textdomain": "my-custom-theme",
  "render": "file:./render.php",
  "attributes": {
    "heading": {
      "type": "string",
      "default": ""
    },
    "items": {
      "type": "array",
      "default": [
        {
          "text": "First benefit or feature"
        },
        {
          "text": "Second benefit or feature"
        },
        {
          "text": "Third benefit or feature"
        }
      ]
    },
    "columns": {
      "type": "string",
      "enum": [
        "1",
        "2"
      ],
      "default": "1"
    },
    "theme": {
      "type": "string",
      "enum": [
        "light",
        "dark"
      ],
      "default": "light"
    },
    "background": {
      "type": "string",
      "enum": [
        "white",
        "gray",
        "none"
      ],
      "default": "none"
    }
  },
  "supports": {
    "html": false,
    "align": false
  }
}