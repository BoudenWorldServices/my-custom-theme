{
  "apiVersion": 2,
  "name": "goliath/svc-text-block",
  "title": "Service Text Block",
  "category": "theme",
  "description": "Flexible text section with optional icon, heading, paragraphs, orange highlight, CTA, and tick list.",
  "supports": {
    "html": false
  },
  "attributes": {
    "bgColor": {
      "type": "string",
      "default": "white"
    },
    "align": {
      "type": "string",
      "default": "center"
    },
    "icon": {
      "type": "string",
      "default": ""
    },
    "heading": {
      "type": "string",
      "default": ""
    },
    "paragraphs": {
      "type": "array",
      "default": []
    },
    "highlight": {
      "type": "string",
      "default": ""
    },
    "highlightPosition": {
      "type": "string",
      "default": "after-first"
    },
    "tickItems": {
      "type": "array",
      "default": []
    },
    "afterListText": {
      "type": "string",
      "default": ""
    },
    "ctaText": {
      "type": "string",
      "default": ""
    },
    "ctaUrl": {
      "type": "string",
      "default": ""
    },
    "statsBanner": {
      "type": "string",
      "default": ""
    },
    "statsBannerCtaText": {
      "type": "string",
      "default": ""
    },
    "statsBannerCtaUrl": {
      "type": "string",
      "default": ""
    }
  },
  "render": "file:./render.php"
}