    "expertFeature1Sub": {
      "type": "string",
      "default": "inspectors"
    },
    "expertFeature2Title": {
      "type": "string",
      "default": "Tailored"
    },
    "expertFeature2Sub": {
      "type": "string",
      "default": "Solution"
    },
    "expertFeature3Title": {
      "type": "string",
      "default": "Analysis"
    },
    "expertFeature3Sub": {
      "type": "string",
      "default": "Report"
    },
    "expertCta1Text": {
      "type": "string",
      "default": "Interested in GOLIATH™?"
    },
    "expertCta1Url": {
      "type": "string",
      "default": "#contact"
    },
    "expertCta2Text": {
      "type": "string",
      "default": "Book My Free Site Survey"
    },
    "expertCta2Url": {
      "type": "string",
      "default": "#contact"
    }
