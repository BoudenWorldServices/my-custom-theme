{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goliath/hero-section",
  "title": "Goliath Hero Section",
  "description": "Dark gradient hero with optional badge, H1 heading, intro paragraph, and optional CTA button. Used at the top of every marketing page.",
  "category": "goliath",
  "icon": "cover-image",
  "keywords": [
    "hero",
    "heading",
    "banner"
  ],
  "textdomain": "my-custom-theme",
  "render": "file:./render.php",
  "attributes": {
    "badge": {
      "type": "string",
      "default": ""
    },
    "heading": {
      "type": "string",
      "default": "Page Heading"
    },
    "headingHighlight": {
      "type": "string",
      "default": ""
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "ctaText": {
      "type": "string",
      "default": ""
    },
    "ctaUrl": {
      "type": "string",
      "default": "/contact/"
    },
    "minHeight": {
      "type": "string",
      "enum": [
        "small",
        "medium",
        "large"
      ],
      "default": "medium"
    }
  },
  "supports": {
    "html": false,
    "align": false,
    "multiple": false
  }
}